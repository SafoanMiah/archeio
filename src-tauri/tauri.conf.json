{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Archeio",
  "mainBinaryName": "Archeio",
  "version": "0.0.1",
  "identifier": "com.archeio.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Archeio",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560,
        "decorations": true,
        "transparent": false,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "resources": [
      "binaries/ffmpeg.exe",
      "binaries/FFMPEG_LICENSE.txt"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
